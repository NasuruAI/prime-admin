# Production environment — loaded automatically by Next.js on `next build`/`start`.
# Browser-facing backend API URL.
NEXT_PUBLIC_API_BASE_URL=https://api.nasuru.com/api/v1

# Server-side (route handlers/RSC/middleware) backend API URL.
API_INTERNAL_BASE_URL=https://api.nasuru.com/api/v1

# Cloudinary cloud name (public) — to preview uploaded assets (e.g. the logo).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dgzxh3ccq
